#!/usr/bin/env node

const Orchestrator = require('../src/orchestrator');
const path = require('path');

const { parseCliArgs } = require('../src/cli-args');

const { presetName, configPath, remaining } = parseCliArgs(process.argv.slice(2));

if (!presetName) {
    console.error('Error: Please specify a preset to run. Usage: go-dev <preset_name> [-c|--config <path>] [--args-for ...]');
    process.exit(1);
}

process.argv = [process.argv[0], process.argv[1], presetName, ...remaining];

const orchestrator = new Orchestrator(configPath);

orchestrator.start(presetName);